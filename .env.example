APP_NAME=CNPJ Data Hub API
APP_ENV=development
APP_DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://cnpj_user:cnpj_password@postgres:5432/cnpj_data_hub

REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=default

DATA_LOCAL_PATH=/app/data
EXPORTS_LOCAL_PATH=/app/exports

ACTIVE_DATASET_VERSION=

EXPORT_MAX_ROWS=50000
EXPORT_EXPIRES_HOURS=24

DOWNLOAD_TIMEOUT_SECONDS=120
DOWNLOAD_MAX_RETRIES=3

LOG_LEVEL=INFO

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
